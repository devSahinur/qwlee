# ---------------------------------------------------------------
# Backend environment variables. Copy this file to `.env` and fill
# in real values. Never commit `.env`.
# ---------------------------------------------------------------

# Server
NODE_ENV=development
PORT=7171
# Interface the HTTP server binds to. Leave blank for default (all
# interfaces). In production set to the public IP or 127.0.0.1
# behind a reverse proxy.
BACKEND_IP=

# Database
MONGODB_URL=mongodb://localhost:27017/cnnctr

# JWT
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=replace-me-with-a-long-random-string
JWT_ACCESS_EXPIRATION_MINUTES=30
JWT_REFRESH_EXPIRATION_DAYS=30
JWT_RESET_PASSWORD_EXPIRATION_MINUTES=10
JWT_VERIFY_EMAIL_EXPIRATION_MINUTES=10

# Frontend URL — used for Stripe success/cancel redirects.
FRONTEND_URL=http://localhost:8000

# CORS — comma-separated list of allowed origins for the API.
# Example: https://qwlee.com,https://admin.qwlee.com,http://localhost:8000,http://localhost:4000
CORS_ORIGINS=http://localhost:8000,http://localhost:4000

# Cloudinary — https://cloudinary.com/
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# SMTP (Gmail app password example)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
EMAIL_FROM=

# Stripe — use TEST keys (sk_test_..., pk_test_..., whsec_...) for local
# development. Get yours from https://dashboard.stripe.com/test/apikeys.
# Webhook secret comes from `stripe listen --forward-to ...` (Stripe CLI).
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=

# ImgBB — https://api.imgbb.com/ (free tier). All image uploads route here.
IMGBB_API_KEY=
MAX_IMAGE_SIZE_MB=32
