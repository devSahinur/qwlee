# ---------------------------------------------------------------
# Frontend (Next.js) environment variables. Copy this file to
# `.env.local` and fill in real values. Never commit secrets.
#
# NEXT_PUBLIC_* values are inlined into the client bundle and
# visible to anyone — only put non-sensitive values here.
# ---------------------------------------------------------------

# Public URL of the backend API + websocket gateway
NEXT_PUBLIC_BACKEND_API_URL=http://localhost:7171
NEXT_PUBLIC_SOCKET_URL=http://localhost:8181
NEXT_PUBLIC_SITE_NAME=Qwlee

# NextAuth — generate with: openssl rand -base64 32
NEXTAUTH_SECRET=replace-me-with-a-long-random-string
NEXTAUTH_URL=http://localhost:8000

# Shared JWT secret — MUST match backend's JWT_SECRET. Used by middleware.js
# to verify access tokens at the edge. Server-side only (no NEXT_PUBLIC_).
JWT_SECRET=replace-me-with-the-same-value-as-backend

